{
  "uid": "microservices-otel",
  "title": "Microservices Observability",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "10s",
  "templating": {
    "list": [
      {
        "name": "service",
        "type": "query",
        "datasource": { "type": "loki", "uid": "Loki" },
        "query": "label_values(service_name)",
        "current": { "text": "all", "value": ".*" }
      }
    ]
  },
  "panels": [
    {
      "type": "timeseries",
      "title": "Process CPU Usage",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "process_cpu_usage",
          "legendFormat": "{{job}}"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 }
    },
    {
      "type": "timeseries",
      "title": "JVM Memory Used",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "jvm_memory_used_bytes",
          "legendFormat": "{{area}}"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 }
    },
    {
      "type": "logs",
      "title": "Application Logs (service.name)",
      "datasource": { "type": "loki", "uid": "Loki" },
      "targets": [
        {
          "expr": "{service_name=~\"$service\"}",
          "refId": "A"
        }
      ],
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 8 }
    },
    {
      "type": "text",
      "title": "Traces (Jaeger)",
      "options": {
        "mode": "markdown",
        "content": "[Ouvrir Jaeger](http://localhost:16686)"
      },
      "gridPos": { "h": 4, "w": 24, "x": 0, "y": 16 }
    },
    {
      "type": "timeseries",
      "title": "Orders Processed (rate)",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "rate(orders_processed_total[5m])",
          "legendFormat": "orders"
        }
      ],
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 20 }
    },
    {
      "type": "timeseries",
      "title": "Payments Processed (rate)",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "rate(payments_processed_total[5m])",
          "legendFormat": "payments"
        }
      ],
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 20 }
    },
    {
      "type": "timeseries",
      "title": "Notifications Sent (rate)",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "rate(notifications_sent_total[5m])",
          "legendFormat": "notifications"
        }
      ],
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 20 }
    },
    {
      "type": "timeseries",
      "title": "Order Processing Duration (avg)",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "rate(orders_processing_duration_seconds_sum[5m]) / rate(orders_processing_duration_seconds_count[5m])",
          "legendFormat": "avg"
        }
      ],
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 28 }
    }
  ],
  "time": { "from": "now-15m", "to": "now" }
}